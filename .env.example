# Copy to .env.local and fill in values for local development.
# See docs/launch-blockers.md for full deployment readiness checklist.
#
# Legend:
#   (required)           — app errors or silently skips core features without this
#   (optional)           — app degrades gracefully; safe to omit in dev
#   (staging-only)       — must NOT be set in production
#   (template-side)      — not read by app code; configure in PDFMonkey template/dashboard
#   (reserved, unused)   — in schema but not used in v1

# ── Database ─────────────────────────────────────────────────────────────────
# (required) Supabase PostgreSQL connection string.
# For Vercel/serverless: use the connection pooler URL (port 6543), not direct (port 5432).
DATABASE_URL=

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# (required) AI Researcher + AI Narrative + Claude tiebreaker.
# Missing → AI fallback narratives used; PDF personalization reduced. Non-fatal.
ANTHROPIC_API_KEY=

# ── PDFMonkey — direct API, no Zapier ────────────────────────────────────────
# (required) Both vars needed; missing → pdfStatus="skipped" for all qualified leads.
PDFMONKEY_API_KEY=
PDFMONKEY_TEMPLATE_ID=

# ── Microsoft Outlook ────────────────────────────────────────────────────────
# (reserved, unused) Email delivery is GHL/Zapier-owned in v1. These vars serve no function.
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# ── Calendly ─────────────────────────────────────────────────────────────────
# (template-side) Injected into PDFMonkey template — not read by app server code.
# Configure this in the PDFMonkey template variables or dashboard.
CALENDLY_URL=

# ── FSIQ logos ───────────────────────────────────────────────────────────────
# (template-side) Injected into PDFMonkey template — not read by app server code.
# Configure these in the PDFMonkey template variables or dashboard.
FSIQ_LOGO_DARK_URL=
FSIQ_LOGO_LIGHT_URL=
FSIQ_IQ_LOGO_URL=

# ── Meta Pixel + Conversions API ─────────────────────────────────────────────
# (required) Set both NEXT_PUBLIC_ and non-public to the same production pixel ID.
# NEXT_PUBLIC_META_PIXEL_ID — embedded at build time, sent to browser (pixel IDs are non-secret by design).
# META_PIXEL_ID — server-side CAPI use only.
# Missing → pixel does not fire (browser) and/or CAPI skipped (server); metaStatus="skipped".
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
# (staging-only) Enables Meta test event mode. Must be blank in production.
META_TEST_EVENT_CODE=

# ── Admin dashboard ───────────────────────────────────────────────────────────
# (required) Protects /admin/* routes. Use a strong random string (32+ chars).
# Store only in .env.local or hosting env vars — never commit a real value.
ADMIN_ACCESS_TOKEN=

# ── GoHighLevel (CRM sync) ────────────────────────────────────────────────────
# (required) GHL_ACCESS_TOKEN preferred; GHL_API_KEY is the fallback.
# Missing → crmSyncStatus="error" for all submissions; no GHL contacts created; no email fires.
GHL_ACCESS_TOKEN=
GHL_API_KEY=
GHL_LOCATION_ID=
# (reserved, unused) GHL pipeline assignment is managed in GHL itself, not via API in v1.
GHL_PIPELINE_ID=
# (optional) Defaults to https://services.leadconnectorhq.com. Override only for non-standard endpoints.
GHL_API_BASE_URL=

# ── Headless browser fallback (Playwright) ────────────────────────────────────
# (optional) Set to "true" only in environments with Chromium available (not Vercel by default).
# When false (default), Playwright fallback is disabled; JS-heavy sites get plausible_unverified.
HEADLESS_ENABLED=
