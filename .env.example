# Copy to .env.local and fill in values for local development.
# All vars marked (required for production) must be set before deploying.

# Database
DATABASE_URL=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# PDFMonkey — direct API, no Zapier
PDFMONKEY_API_KEY=
PDFMONKEY_TEMPLATE_ID=

# Microsoft Outlook (email delivery)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# Google Places API (website validation + country eligibility)
GOOGLE_PLACES_API_KEY=

# Calendly
CALENDLY_URL=

# FSIQ logos
FSIQ_LOGO_DARK_URL=
FSIQ_LOGO_LIGHT_URL=
FSIQ_IQ_LOGO_URL=

# Meta Pixel + Conversions API (required for production tracking)
META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=

# GoHighLevel (CRM sync)
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
