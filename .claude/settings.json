{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous-commands.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-after-edit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-scan.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/docs-change-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-reminder.sh"
          }
        ]
      }
    ]
  }
}
